@page "/"
@using DisplayCapture.Services
@using DisplayCapture.Models
@inject ScreenCaptureService CaptureService
@inject IJSRuntime JS
@inject ILogger<Home> Logger
@rendermode InteractiveServer

<PageTitle>Display Capture</PageTitle>

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <h1 class="text-center mb-4">
                <i class="fas fa-video"></i> Display Capture Tool
            </h1>
            <p class="text-center text-muted">Capture a portion of your screen with mouse interactions</p>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-body">
                    @if (_currentStep == CaptureStep.Configure)
                    {
                        <h4 class="card-title">Step 1: Configure Capture Area</h4>
                        
                        <div class="form-group mb-3">
                            <label for="xPos">X Position:</label>
                            <input type="number" @bind="_captureArea.X" class="form-control" id="xPos" min="0" />
                        </div>
                        
                        <div class="form-group mb-3">
                            <label for="yPos">Y Position:</label>
                            <input type="number" @bind="_captureArea.Y" class="form-control" id="yPos" min="0" />
                        </div>
                        
                        <div class="form-group mb-3">
                            <label for="width">Width:</label>
                            <input type="number" @bind="_captureArea.Width" class="form-control" id="width" min="100" />
                        </div>
                        
                        <div class="form-group mb-3">
                            <label for="height">Height:</label>
                            <input type="number" @bind="_captureArea.Height" class="form-control" id="height" min="100" />
                        </div>

                        <div class="form-group mb-3">
                            <label for="duration">Recording Duration (seconds):</label>
                            <input type="number" @bind="_recordingDuration" class="form-control" id="duration" min="5" max="300" />
                        </div>

                        <div class="d-grid gap-2">
                            <button class="btn btn-primary btn-lg" @onclick="StartCountdown" disabled="@(!_captureArea.IsValid)">
                                <i class="fas fa-play"></i> Start Recording
                            </button>
                        </div>
                        
                        <div class="mt-3">
                            <small class="text-muted">
                                <strong>Quick presets:</strong><br/>
                                <button type="button" class="btn btn-sm btn-outline-secondary me-2" @onclick="() => SetPreset(800, 600)">800x600</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary me-2" @onclick="() => SetPreset(1280, 720)">1280x720 (HD)</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => SetPreset(1920, 1080)">1920x1080 (FHD)</button>
                            </small>
                        </div>
                    }
                    else if (_currentStep == CaptureStep.Countdown)
                    {
                        <div class="text-center">
                            <h2 class="mb-4">Get Ready!</h2>
                            <div class="countdown-display">
                                <span class="countdown-number">@_countdownSeconds</span>
                            </div>
                            <p class="text-muted mt-3">Recording will start in...</p>
                            <button class="btn btn-secondary" @onclick="CancelCountdown">
                                <i class="fas fa-times"></i> Cancel
                            </button>
                        </div>
                    }
                    else if (_currentStep == CaptureStep.Recording)
                    {
                        <div class="text-center">
                            <h2 class="mb-4 text-danger">
                                <i class="fas fa-record-vinyl blinking"></i> Recording in Progress
                            </h2>
                            <div class="recording-info">
                                <p><strong>Area:</strong> @_captureArea.Width x @_captureArea.Height px</p>
                                <p><strong>Position:</strong> (@_captureArea.X, @_captureArea.Y)</p>
                                <p><strong>Duration:</strong> @_recordingDuration seconds</p>
                            </div>
                            <button class="btn btn-danger btn-lg" @onclick="StopRecording">
                                <i class="fas fa-stop"></i> Stop Recording
                            </button>
                        </div>
                    }
                    else if (_currentStep == CaptureStep.Complete)
                    {
                        <div class="text-center">
                            <h2 class="mb-4 text-success">
                                <i class="fas fa-check-circle"></i> Recording Complete!
                            </h2>
                            @if (!string.IsNullOrEmpty(_lastRecordingPath))
                            {
                                <div class="alert alert-success">
                                    <strong>File saved:</strong> @Path.GetFileName(_lastRecordingPath)
                                </div>
                            }
                            <div class="d-grid gap-2">
                                <button class="btn btn-primary" @onclick="StartNew">
                                    <i class="fas fa-plus"></i> New Recording
                                </button>
                                <button class="btn btn-secondary" @onclick="OpenOutputFolder">
                                    <i class="fas fa-folder-open"></i> Open Output Folder
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (_recentFiles.Any())
    {
        <div class="row justify-content-center mt-4">
            <div class="col-md-8">
                <div class="card">
                    <div class="card-header">
                        <h5><i class="fas fa-history"></i> Recent Recordings</h5>
                    </div>
                    <div class="card-body">
                        <div class="list-group">
                            @foreach (var file in _recentFiles.Take(5))
                            {
                                <div class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong>@Path.GetFileName(file)</strong><br />
                                        <small class="text-muted">@File.GetCreationTime(file).ToString("yyyy-MM-dd HH:mm:ss")</small>
                                    </div>
                                    <span class="badge bg-primary rounded-pill">@FormatFileSize(new FileInfo(file).Length)</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private CaptureArea _captureArea = new() { X = 100, Y = 100, Width = 800, Height = 600 };
    private int _recordingDuration = 30;
    private CaptureStep _currentStep = CaptureStep.Configure;
    private int _countdownSeconds = 5;
    private Timer? _countdownTimer;
    private string _lastRecordingPath = string.Empty;
    private string[] _recentFiles = Array.Empty<string>();

    private enum CaptureStep
    {
        Configure,
        Countdown,
        Recording,
        Complete
    }

    protected override void OnInitialized()
    {
        RefreshRecentFiles();
    }

    private void SetPreset(int width, int height)
    {
        _captureArea.Width = width;
        _captureArea.Height = height;
    }

    private void StartCountdown()
    {
        if (!_captureArea.IsValid)
            return;

        _currentStep = CaptureStep.Countdown;
        _countdownSeconds = 5;
        
        _countdownTimer = new Timer(async _ => await CountdownTick(), null, TimeSpan.Zero, TimeSpan.FromSeconds(1));
    }

    private async Task CountdownTick()
    {
        _countdownSeconds--;
        
        await InvokeAsync(StateHasChanged);
        
        if (_countdownSeconds <= 0)
        {
            _countdownTimer?.Dispose();
            _countdownTimer = null;
            await StartRecording();
        }
    }

    private void CancelCountdown()
    {
        _countdownTimer?.Dispose();
        _countdownTimer = null;
        _currentStep = CaptureStep.Configure;
    }

    private async Task StartRecording()
    {
        try
        {
            _currentStep = CaptureStep.Recording;
            _lastRecordingPath = await CaptureService.StartRecordingAsync(_captureArea, _recordingDuration);
            
            // Set up a timer to automatically stop recording after the specified duration
            _ = Task.Delay(TimeSpan.FromSeconds(_recordingDuration)).ContinueWith(async _ =>
            {
                if (_currentStep == CaptureStep.Recording)
                {
                    await StopRecording();
                }
            });
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to start recording");
            _currentStep = CaptureStep.Configure;
            await JS.InvokeVoidAsync("alert", $"Failed to start recording: {ex.Message}");
        }
    }

    private async Task StopRecording()
    {
        try
        {
            await CaptureService.StopRecordingAsync();
            _currentStep = CaptureStep.Complete;
            RefreshRecentFiles();
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to stop recording");
            await JS.InvokeVoidAsync("alert", $"Failed to stop recording: {ex.Message}");
        }
    }

    private void StartNew()
    {
        _currentStep = CaptureStep.Configure;
        _lastRecordingPath = string.Empty;
    }

    private async Task OpenOutputFolder()
    {
        try
        {
            var outputDir = CaptureService.OutputDirectory;
            if (OperatingSystem.IsWindows())
            {
                System.Diagnostics.Process.Start("explorer.exe", outputDir);
            }
            else if (OperatingSystem.IsMacOS())
            {
                System.Diagnostics.Process.Start("open", outputDir);
            }
            else if (OperatingSystem.IsLinux())
            {
                System.Diagnostics.Process.Start("xdg-open", outputDir);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to open output folder");
            await JS.InvokeVoidAsync("alert", $"Output folder: {CaptureService.OutputDirectory}");
        }
    }

    private void RefreshRecentFiles()
    {
        _recentFiles = CaptureService.GetRecordedFiles();
    }

    private string FormatFileSize(long bytes)
    {
        string[] suffixes = { "B", "KB", "MB", "GB", "TB" };
        int counter = 0;
        decimal number = bytes;
        while (Math.Round(number / 1024) >= 1)
        {
            number /= 1024;
            counter++;
        }
        return $"{number:n1} {suffixes[counter]}";
    }

    public void Dispose()
    {
        _countdownTimer?.Dispose();
    }
}
